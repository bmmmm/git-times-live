# git-times-live — forge configuration (PLACEHOLDERS ONLY).
#
# Copy to .env and fill in real values. .env is gitignored — NEVER commit it,
# and NEVER put a real host, owner, user, or token in THIS example file.
#
# Only set the block(s) for the forge(s) you actually use. Leave the rest empty
# and that forge is skipped. Run with --scope local to skip all forge polling.

# ── Repo discovery ──────────────────────────────────────────────────────────
# Space-separated roots to scan for git repos (the launch-cwd repo is always
# included on top of these).
GIT_TIMES_ROOTS="$HOME/code $HOME/projects $HOME/src $HOME/dev"

# ── Forgejo / Gitea ─────────────────────────────────────────────────────────
GIT_TIMES_FORGEJO_HOST="forgejo.example.com"
GIT_TIMES_FORGEJO_OWNER="your-org"
GIT_TIMES_FORGEJO_TOKEN=""

# ── GitHub ──────────────────────────────────────────────────────────────────
GIT_TIMES_GITHUB_USER="your-user"
GIT_TIMES_GITHUB_TOKEN=""

# ── GitLab ──────────────────────────────────────────────────────────────────
GIT_TIMES_GITLAB_HOST="gitlab.example.com"
GIT_TIMES_GITLAB_TOKEN=""

# ── Live tunables (optional; see README for the full table) ─────────────────
# GIT_TIMES_LIVE_INTERVAL=10
# GIT_TIMES_LIVE_REMOTE_INTERVAL=90
# GIT_TIMES_LIVE_TICKER=off
# GIT_TIMES_THEME=neon
